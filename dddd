<script>
const C=document.getElementById('C'),CR=document.getElementById('CR');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  C.style.left=mx+'px';C.style.top=my+'px';
  const t=document.createElement('div');t.className='ctr';
  const s=1.5+Math.random()*3;
  t.style.cssText=`left:${mx}px;top:${my}px;width:${s}px;height:${s}px;background:rgba(240,192,64,${.06+Math.random()*.13})`;
  document.body.appendChild(t);setTimeout(()=>t.remove(),550);
});
(function loop(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;CR.style.left=rx+'px';CR.style.top=ry+'px';requestAnimationFrame(loop)})();
document.addEventListener('mousedown',()=>{C.classList.add('ck');for(let i=0;i<7;i++){const b=document.createElement('div'),a=(i/7)*Math.PI*2,d=14+Math.random()*12;b.className='ctr';b.style.cssText=`left:${mx}px;top:${my}px;width:4px;height:4px;background:rgba(240,192,64,.7);transition:left .3s,top .3s,opacity .3s`;document.body.appendChild(b);requestAnimationFrame(()=>{b.style.left=(mx+Math.cos(a)*d)+'px';b.style.top=(my+Math.sin(a)*d)+'px';b.style.opacity='0'});setTimeout(()=>b.remove(),360)}});
document.addEventListener('mouseup',()=>C.classList.remove('ck'));
document.addEventListener('mouseover',e=>{if(e.target.closest('a,button,.nav-card,.tmi'))CR.classList.add('hv')});
document.addEventListener('mouseout',e=>{if(e.target.closest('a,button,.nav-card,.tmi'))CR.classList.remove('hv')});
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('sol',scrollY>30));
const ro=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');ro.unobserve(e.target)}})},{threshold:.1});
document.querySelectorAll('.rv,.rv-l').forEach((el,i)=>{el.style.transitionDelay=(i%5)*55+'ms';ro.observe(el)});
function cnt(el,to,sfx){let v=0;const s=Math.max(1,Math.floor(to/50)),t=setInterval(()=>{v=Math.min(v+s,to);el.textContent=v.toLocaleString()+sfx;if(v>=to)clearInterval(t)},28)}
setTimeout(()=>{cnt(document.getElementById('hv1'),1248,'');cnt(document.getElementById('hv2'),5,'');cnt(document.getElementById('hv3'),84,'K')},500);
</script>
